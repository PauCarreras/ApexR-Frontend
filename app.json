{
  "expo": {
    "name": "ApexR",
    "slug": "apexr",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "apexr",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
